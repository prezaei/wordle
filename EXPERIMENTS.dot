  validity_max_v2 -> validity_max_v3 [label="aux 8 — plateaus"];
  fair_stage1 -> infill [label="clue-aware infill (template input, clue logic training-only)"];
  fair_stage1 -> constrained_decode [label="mask spelling (diagnostic)"];
  fair_stage1 -> bestof16 [label="test-time compute"];
  fair_stage1 -> bestof16_nodict [label="no-dict ablation"];
  bestof16 -> bestof64 [label="N=64"];
  bestof64 -> bestof128 [label="N=128"];
  fair_stage1 -> beam_trie [label="beam"];
  cot_eph_aux -> deployed [label="deployed framing"];
  dpo_commit -> deployed [label="best deployed"];
}
